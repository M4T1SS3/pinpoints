{
  "name": "pinpoint",
  "displayName": "PinPoint",
  "description": "Click any UI element in your browser to instantly Capture its HTML, styles, and layout context for your AI coding assistant. No more screenshots.",
  "version": "0.1.6",
  "publisher": "pinpointpoint",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/M4T1SS3/pinpoint.git"
  },
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./out/extension.js",
  "bin": {
    "pinpoint": "out/cli/index.js"
  },
  "files": [
    "out/**",
    "resources/**",
    "README.md",
    "LICENSE"
  ],
  "contributes": {
    "icons": {
      "pinpoint-logo": {
        "description": "PinPoint Logo",
        "default": {
          "fontPath": "./resources/fonts/icons.woff",
          "fontCharacter": "\\F101"
        }
      }
    },
    "commands": [
      {
        "command": "pinpoint.startPicker",
        "title": "Start PinPoint",
        "category": "PinPoint",
        "icon": "$(target)"
      },
      {
        "command": "pinpoint.stopPicker",
        "title": "PinPoint: Stop Picker",
        "category": "PinPoint"
      },
      {
        "command": "pinpoint.clearSelection",
        "title": "PinPoint: Clear Selection",
        "category": "PinPoint"
      }
    ],
    "configuration": {
      "title": "PinPoint",
      "properties": {
        "pinpoint.defaultMode": {
          "type": "string",
          "enum": [
            "pick",
            "full"
          ],
          "default": "pick",
          "description": "Default capture mode"
        },
        "pinpoint.screenshotEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable element screenshots by default"
        },
        "pinpoint.contextRadius": {
          "type": "number",
          "default": 1,
          "minimum": 0,
          "maximum": 3,
          "description": "Number of parent levels to include in context"
        },
        "pinpoint.injectionTarget": {
          "type": "string",
          "enum": [
            "claude-code",
            "copilot-chat",
            "clipboard"
          ],
          "default": "claude-code",
          "enumDescriptions": [
            "Inject into Claude Code chat panel",
            "Inject into GitHub Copilot Chat panel",
            "Copy to clipboard"
          ],
          "description": "Where to inject captured element context"
        }
      }
    },
    "menus": {
      "editor/title": [
        {
          "command": "pinpoint.startPicker",
          "group": "navigation",
          "when": "editorLangId == typescript || editorLangId == javascript || editorLangId == typescriptreact || editorLangId == javascriptreact || editorLangId == html"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "tsc -p ./ --noEmit",
    "test": "npm run compile"
  },
  "devDependencies": {
    "@types/jimp": "^0.2.28",
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@jridgewell/trace-mapping": "^0.3.31",
    "jimp": "^0.22.12",
    "puppeteer-core": "^24.37.5",
    "zod": "^4.3.6"
  }
}
