{
  "name": "pinpoints",
  "displayName": "PinPoints",
  "description": "Click any UI element in your browser to instantly Capture its HTML, styles, and layout context for your AI coding assistant. No more screenshots.",
  "version": "0.1.9",
  "publisher": "pinpointpoint",
  "license": "Custom",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/M4T1SS3/pinpoints.git"
  },
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./out/extension.js",
  "bin": {
    "pinpoints": "out/cli/index.js"
  },
  "contributes": {
    "icons": {
      "pinpoint-logo": {
        "description": "PinPoints Logo",
        "default": {
          "fontPath": "./resources/fonts/icons.woff",
          "fontCharacter": "\\F101"
        }
      }
    },
    "commands": [
      {
        "command": "pinpoints.startPicker",
        "title": "Start PinPoints",
        "category": "PinPoints",
        "icon": "$(target)"
      },
      {
        "command": "pinpoints.stopPicker",
        "title": "PinPoints: Stop Picker",
        "category": "PinPoints"
      },
      {
        "command": "pinpoints.clearSelection",
        "title": "PinPoints: Clear Selection",
        "category": "PinPoints"
      }
    ],
    "configuration": {
      "title": "PinPoints",
      "properties": {
        "pinpoints.defaultMode": {
          "type": "string",
          "enum": [
            "pick",
            "full"
          ],
          "default": "pick",
          "enumDescriptions": [
            "Quick context mode",
            "Screenshot mode"
          ],
          "description": "Default capture mode (pick or screenshot)"
        },
        "pinpoints.screenshotEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable element screenshots by default"
        },
        "pinpoints.contextRadius": {
          "type": "number",
          "default": 1,
          "minimum": 0,
          "maximum": 3,
          "description": "Number of parent levels to include in context"
        },
        "pinpoints.injectionTarget": {
          "type": "string",
          "enum": [
            "claude-code",
            "copilot-chat",
            "clipboard"
          ],
          "default": "claude-code",
          "enumDescriptions": [
            "Inject into Claude Code chat panel",
            "Inject into GitHub Copilot Chat panel",
            "Copy to clipboard"
          ],
          "description": "Where to inject captured element context"
        }
      }
    },
    "menus": {
      "editor/title": [
        {
          "command": "pinpoints.startPicker",
          "group": "navigation",
          "when": "editorLangId == typescript || editorLangId == javascript || editorLangId == typescriptreact || editorLangId == javascriptreact || editorLangId == html"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "tsc -p ./ --noEmit",
    "test": "npm run compile",
    "release:local": "bash ./scripts/release-local.sh",
    "release:local:dry-run": "bash ./scripts/release-local.sh --dry-run",
    "release:patch": "bash ./scripts/release-local.sh --bump patch",
    "release:minor": "bash ./scripts/release-local.sh --bump minor",
    "release:major": "bash ./scripts/release-local.sh --bump major",
    "release:versions": "bash ./scripts/release-local.sh --check-only",
    "release:patch:dry-run": "bash ./scripts/release-local.sh --dry-run --bump patch",
    "release:minor:dry-run": "bash ./scripts/release-local.sh --dry-run --bump minor",
    "release:major:dry-run": "bash ./scripts/release-local.sh --dry-run --bump major"
  },
  "devDependencies": {
    "@types/jimp": "^0.2.28",
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@jridgewell/trace-mapping": "^0.3.31",
    "jimp": "^0.22.12",
    "puppeteer-core": "^24.37.5",
    "zod": "^4.3.6"
  }
}
